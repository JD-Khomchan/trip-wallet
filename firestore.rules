rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin list — authenticated users อ่านได้ ไม่มีใครเขียนได้จาก client
    match /config/admins {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Shared trip plan — ทุกคนอ่านได้ เฉพาะ admin เขียนได้
    match /trips/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.email in get(/databases/$(database)/documents/config/admins).data.emails;
    }

    // User data — เจ้าของเท่านั้น
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
